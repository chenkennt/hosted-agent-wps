AZURE_OPENAI_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project>
# API key is optional if the agent can use managed identity / DefaultAzureCredential.
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=<your-chat-deployment-name>
CHAT_SYSTEM_PROMPT=You are a concise, practical assistant.
CHAT_HISTORY_MAX_MESSAGES=20

WEBPUBSUB_CONNECTION_STRING=Endpoint=https://<your-webpubsub>.webpubsub.azure.com;AccessKey=<key>;Version=1.0;
WEBPUBSUB_HUB=chat
WEBPUBSUB_TRANSPORT=service
WEBPUBSUB_AGENT_USER_ID=hosted-agent
# Optional. If unset, Copilot chooses the default model available to your account.
COPILOT_MODEL=
# Required for GitHub-authenticated Copilot SDK usage in hosted/non-interactive environments.
COPILOT_GITHUB_TOKEN=<github-token-with-copilot-access>
# Optional: directory Copilot should treat as its working directory and writable home.
# For local testing, use a focused project folder, not a large parent directory.
COPILOT_WORKDIR=
COPILOT_HOME=/tmp/copilot
COPILOT_AVAILABLE_TOOLS=
COPILOT_EXCLUDED_TOOLS=
COPILOT_APPROVAL_TIMEOUT_SECONDS=600
COPILOT_AGENT_DEBUG_LOGS=false
# Scope used by the local web UI proxy when calling deployed Foundry agent endpoints.
FOUNDRY_AGENT_AUTH_SCOPE=https://ai.azure.com/.default
FOUNDRY_AGENT_API_VERSION=2025-11-15-preview

# Use this for local Web PubSub dry runs. Do not set it in production.
# MOCK_WEBPUBSUB=true
